# ==============================================================
# O QUE É O 'f' ANTES DAS ASPAS? (f-strings)
# ==============================================================

nome = "Lucas"
idade = 20

# SEM O 'f': O Python lê tudo como texto puro
print("Olá {nome}, você tem {idade} anos") 
# Saída: Olá {nome}, você tem {idade} anos

# COM O 'f': O Python "ativa" as chaves e busca os valores
print(f"Olá {nome}, você tem {idade} anos")
# Saída: Olá Lucas, você tem 20 anos

# --------------------------------------------------------------
# POR QUE USAR?
# 1. VELOCIDADE: É a forma mais rápida de processar texto em Python.
# 2. LIMPEZA: Você lê a frase exatamente como ela vai aparecer.
# 3. PODER: Pode fazer contas direto nelas: f"Dobro: {n1 * 2}"
# ==============================================================

# ==============================================================
# GUIA DE IMPRESSÃO (PRINT) E FORMATAÇÃO NO PYTHON
# ==============================================================

# 1. O 'f' (f-string) -> O ATIVADOR DE CÓDIGO
# Use ANTES das aspas para o Python ler o que está dentro de { }
nome = "Python"
print(f"Estudando {nome}")     # Saída: Estudando Python
print(f"Soma: {5 + 5}")         # Saída: Soma: 10


# 2. O '\n' -> O QUEBRADOR DE LINHA
# Use DENTRO das aspas para "apertar o Enter" no meio do texto
print("Linha 1 \nLinha 2")      
# Saída:
# Linha 1
# Linha 2


# 3. O 'end=' -> O UNIDOR DE LINHAS
# Por padrão, o print() pula linha no final. O end='' impede isso.
print("Olá", end=" ")           # Troca o "Enter" por um espaço
print("Mundo!")                 # Saída: Olá Mundo! (na mesma linha)


# 4. QUANDO USAR CADA UM? (RESUMO)
# --------------------------------------------------------------
# f-string  -> Sempre que precisar colocar variáveis ou contas no print.
# \n        -> Para organizar textos longos ou fazer listas no console.
# end=''    -> Para juntar dois prints diferentes na mesma linha do terminal.
